    rel:memilikiFrasa ex:Frasa_17_1,
        ex:Frasa_17_2,
        ex:Frasa_17_3,
        ex:Frasa_17_4 ;
    rel:teksArab "لاَ تَحَاسَدُوا وَلاَ تَبَاغَضُوا وَلاَ تَقَاطَعُوا وَكُونُوا عِبَادَ اللَّهِ إِخْوَانًا"@ar ;
    rel:teksLatin "Laa tahaasaduu wa laa tabaaghadhuu wa laa taqaatha'uu wa kuunuu 'ibaadallahi ikhwaanaa."@id-Latn ;
    rel:terjemahan "Janganlah kalian saling hasad, janganlah saling membenci, janganlah saling memutus hubungan, dan jadilah kalian hamba-hamba Allah yang bersaudara."@id .

ex:Hadis_18 a ex:Hadis ;
    rel:diriwayatkanOleh ex:Abdullah_bin_Masud ;
    rel:jumlahKarakterArab 76 ;
    rel:membahasTopik ex:Berbakti_Kepada_Orang_Tua ;
    rel:memilikiFrasa ex:Frasa_18_1,
        ex:Frasa_18_2,
        ex:Frasa_18_3,
        ex:Frasa_18_4 ;
    rel:teksArab "رِضَا الرَّبِّ فِي رِضَا الْوَالِدِ، وَسَخَطُ الرَّبِّ فِي سَخَطِ الْوَالِدِ"@ar ;
    rel:teksLatin "Ridhar-rabbi fii ridhal-waalid, wa sakhathur-rabbi fii sakhathil-waalid."@id-Latn ;
    rel:terjemahan "Ridha Allah terletak pada ridha orang tua, dan murka Allah terletak pada murka orang tua."@id .

ex:Hadis_20 a ex:Hadis ;
    rel:diriwayatkanOleh ex:Abu_Hurairah ;
    rel:jumlahKarakterArab 112 ;
    rel:membahasTopik ex:Allah_Tidak_Melihat_Bentuk_Rupamu ;
    rel:memilikiFrasa ex:Frasa_20_1,
        ex:Frasa_20_2,
        ex:Frasa_20_3,
        ex:Frasa_20_4 ;
    rel:teksArab "إِنَّ اللَّهَ لاَ يَنْظُرُ إِلَى صُوَرِكُمْ وَأَمْوَالِكُمْ، وَلَكِنْ يَنْظُرُ إِلَى قُلُوبِكُمْ وَأَعْمَالِكُمْ"@ar ;
    rel:teksLatin "Innallaha laa yandzuru ilaa shuwarikum wa amwaalikum, wa laakin yandzuru ilaa quluubikum wa a'maalikum."@id-Latn ;
    rel:terjemahan "Sesungguhnya Allah tidak melihat kepada rupa dan harta kalian, melainkan Dia melihat kepada hati dan amal kalian."@id .

ex:Hadis_4 a ex:Hadis ;
    rel:diriwayatkanOleh ex:Aisyah ;
    rel:jumlahKarakterArab 64 ;
    rel:membahasTopik <http://proyekakhir.ac.id/concept/Bid'ah_dan_Menyelisihi_Sunnah> ;
    rel:memilikiFrasa ex:Frasa_4_1,
        ex:Frasa_4_2,
        ex:Frasa_4_3,
        ex:Frasa_4_4 ;
    rel:teksArab "مَنْ أَحْدَثَ فِي أَمْرِنَا هَذَا مَا لَيْسَ مِنْهُ فَهُوَ رَدٌّ"@ar ;
    rel:teksLatin "Man ahdatsa fii amrinaa hadza maa laisa minhu fahuwa raddun."@id-Latn ;
    rel:terjemahan "Barangsiapa yang mengada-adakan sesuatu hal yang baru dalam perkara agama kami ini yang tidak ada dasar darinya, maka ia tertolak."@id .

ex:Hadis_5 a ex:Hadis ;
    rel:diriwayatkanOleh ex:Numan_bin_Basyir ;
    rel:jumlahKarakterArab 86 ;
    rel:membahasTopik ex:Halal_dan_Haram ;
    rel:memilikiFrasa ex:Frasa_5_1,
        ex:Frasa_5_2,
        ex:Frasa_5_3,
        ex:Frasa_5_4 ;
    rel:teksArab "إِنَّ الْحَلالَ بَيِّنٌ وَإِنَّ الْحَرَامَ بَيِّنٌ وَبَيْنَهُمَا أُمُورٌ مُشْتَبِهَاتٌ"@ar ;
    rel:teksLatin "Innal halaala bayyinun wa innal haraama bayyinun wa bainahumaa umuurun musytabihaatun."@id-Latn ;
    rel:terjemahan "Sesungguhnya yang halal itu jelas, dan sesungguhnya yang haram itu jelas, dan di antara keduanya terdapat perkara-perkara syubhat (samar)."@id .

ex:Hadis_9 a ex:Hadis ;
    rel:diriwayatkanOleh ex:Ibnu_Masud ;
    rel:jumlahKarakterArab 107 ;
    rel:membahasTopik ex:Malu_adalah_Sebagian_dari_Iman ;
    rel:memilikiFrasa ex:Frasa_9_1,
        ex:Frasa_9_2,
        ex:Frasa_9_3,
        ex:Frasa_9_4 ;
    rel:teksArab "إِنَّ مِمَّا أَدْرَكَ النَّاسُ مِنْ كَلاَمِ النُّبُوَّةِ الأُولَى: إِذَا لَمْ تَسْتَحِ فَاصْنَعْ مَا شِئْتَ"@ar ;
    rel:teksLatin "Inna mimmaa adrakan-naasu min kalaamin-nubuwwatil uulaa: idzaa lam tastahi fashna' maa syi'ta."@id-Latn ;
    rel:terjemahan "Sesungguhnya di antara perkataan kenabian pertama yang didapati oleh manusia adalah: Jika kamu tidak malu, maka berbuatlah sesukamu."@id .

ex:Hadis_1 a ex:Hadis ;
    rel:diriwayatkanOleh ex:Umar_bin_Khattab ;
    rel:jumlahKarakterArab 72 ;
    rel:membahasTopik ex:Niat_dan_Ikhlas ;
    rel:memilikiFrasa ex:Frasa_1_1,
        ex:Frasa_1_2,
        ex:Frasa_1_3,
        ex:Frasa_1_4,
        ex:Frasa_1_5 ;
    rel:teksArab "إِنَّمَا الأَعْمَالُ بِالنِّيَّاتِ، وَإِنَّمَا لِكُلِّ امْرِئٍ مَا نَوَى"@ar ;
    rel:teksLatin "Innamal a'malu bin-niyyaat, wa innamaa likullimri'in maa nawaa."@id-Latn ;
    rel:terjemahan "Sesungguhnya amalan itu tergantung pada niatnya, dan sesungguhnya setiap orang akan mendapatkan apa yang ia niatkan."@id .

ex:Hadis_11 a ex:Hadis ;
    rel:diriwayatkanOleh ex:Abu_Hurairah ;
    rel:jumlahKarakterArab 122 ;
    rel:membahasTopik ex:Tolong_Menolong_dan_Menutup_Aib ;
    rel:memilikiFrasa ex:Frasa_11_1,
        ex:Frasa_11_2,
        ex:Frasa_11_3,
        ex:Frasa_11_4,
        ex:Frasa_11_5 ;
    rel:teksArab "مَنْ نَفَّسَ عَنْ مُؤْمِنٍ كُرْبَةً مِنْ كُرَبِ الدُّنْيَا نَفَّسَ اللَّهُ عَنْهُ كُرْبَةً مِنْ كُرَبِ يَوْمِ الْقِيَامَةِ"@ar ;
    rel:teksLatin "Man naffasa 'an mu'minin kurbatan min kurabid-dunya naffasallahu 'anhu kurbatan min kurabi yaumil-qiyaamah."@id-Latn ;
    rel:terjemahan "Barangsiapa yang melepaskan satu kesusahan dunia dari seorang mukmin, Allah akan melepaskan darinya satu kesusahan di hari kiamat."@id .

ex:Hadis_16 a ex:Hadis ;
    rel:diriwayatkanOleh ex:Abu_Said_Al-Khudri ;
    rel:jumlahKarakterArab 158 ;
    rel:membahasTopik ex:Kezaliman_Diingkari_walau_Hanya_dalam_Hati ;
    rel:memilikiFrasa ex:Frasa_16_1,
        ex:Frasa_16_2,
        ex:Frasa_16_3,
        ex:Frasa_16_4,
        ex:Frasa_16_5 ;
    rel:teksArab "مَنْ رَأَى مِنْكُمْ مُنْكَرًا فَلْيُغَيِّرْهُ بِيَدِهِ، فَإِنْ لَمْ يَسْتَطِعْ فَبِلِسَانِهِ، فَإِنْ لَمْ يَسْتَطِعْ فَبِقَلْبِهِ وَذَلِكَ أَضْعَفُ الإِيمَانِ"@ar ;
    rel:teksLatin "Man ra'a minkum munkaran fal-yughayyirhu biyadihi, fa in lam yastathi' fabilisaanihi, fa in lam yastathi' fabiqalbihi wa dzaalika adh'aful-iimaan."@id-Latn ;
    rel:terjemahan "Barangsiapa di antara kalian melihat kemungkaran, hendaklah ia mengubahnya dengan tangannya; jika tidak mampu, maka dengan lisannya; jika tidak mampu, maka dengan hatinya, dan itulah selemah-lemah iman."@id .

ex:Abu_Hurairah a ex:Perawi .

ex:Hadis_19 a ex:Hadis ;
    rel:diriwayatkanOleh ex:Numan_bin_Basyir ;
    rel:jumlahKarakterArab 172 ;
    rel:membahasTopik ex:Kasih_Sayang_Sesama_Muslim ;
    rel:memilikiFrasa ex:Frasa_19_1,
        ex:Frasa_19_2,
        ex:Frasa_19_3,
        ex:Frasa_19_4,
        ex:Frasa_19_5,
        ex:Frasa_19_6,
        ex:Frasa_19_7,
        ex:Frasa_19_8 ;
    rel:teksArab "مَثَلُ الْمُؤْمِنِينَ فِي تَوَادِّهِمْ وَتَرَاحُمِهِمْ وَتَعَاطُفِهِمْ مَثَلُ الْجَسَدِ إِذَا اشْتَكَى مِنْهُ عُضْوٌ تَدَاعَى لَهُ سَائِرُ الْجَسَدِ بِالسَّهَرِ وَالْحُمَّى"@ar ;
    rel:teksLatin "Matsalul-mu'miniina fii tawaaddihim wa taraahumihim wa ta'aathufihim matsalul-jasadi idzasy-takaa minhu 'udhwun tadaa'aa lahu saa'irul-jasadi bis-sahari wal-hummaa."@id-Latn ;
    rel:terjemahan "Perumpamaan kaum mukminin dalam saling mencintai, saling mengasihi, dan saling menyayangi adalah seperti satu tubuh; jika satu bagian merasa sakit, maka seluruh tubuh akan ikut merasakannya dengan tidak bisa tidur and demam."@id .

ex:Hadis_3 a ex:Hadis ;
    rel:diriwayatkanOleh ex:Ibnu_Masud ;
    rel:jumlahKarakterArab 158 ;
    rel:membahasTopik ex:Penciptaan_Manusia ;
    rel:memilikiFrasa ex:Frasa_3_1,
        ex:Frasa_3_2,
        ex:Frasa_3_3,
        ex:Frasa_3_4,
        ex:Frasa_3_5,
        ex:Frasa_3_6,
        ex:Frasa_3_7,
        ex:Frasa_3_8 ;
    rel:teksArab "إِنَّ أَحَدَكُمْ يُجْمَعُ خَلْقُهُ فِي بَطْنِ أُمِّهِ أَرْبَعِينَ يَوْمًا نُطْفَةً، ثُمَّ يَكُونُ عَلَقَةً مِثْلَ ذَلِكَ، ثُمَّ يَكُونُ مُضْغَةً مِثْلَ ذَلِكَ"@ar ;
    rel:teksLatin "Inna ahadakum yujma'u khalquhu fii bathni ummihi arba'iina yauman nuthfatan, thumma yakuunu 'alaqatan mithla dzaalika, thumma yakuunu mudhghatan mithla dzaalika."@id-Latn ;
    rel:terjemahan "Sesungguhnya salah seorang dari kalian dikumpulkan penciptaannya dalam perut ibunya selama 40 hari berwujud nutfah (mani), kemudian menjadi 'alaqah (segumpal darah) selama itu pula, kemudian menjadi mudhghah (segumpal daging) selama itu pula."@id .

ex:Hadis_2 a ex:Hadis ;
    rel:diriwayatkanOleh ex:Ibnu_Umar ;
    rel:jumlahKarakterArab 190 ;
    rel:membahasTopik ex:Rukun_Islam ;
    rel:memilikiFrasa ex:Frasa_2_1,
        ex:Frasa_2_2,
        ex:Frasa_2_3,
        ex:Frasa_2_4,
        ex:Frasa_2_5,
        ex:Frasa_2_6,
        ex:Frasa_2_7,
        ex:Frasa_2_8,
        ex:Frasa_2_9 ;
    rel:teksArab "بُنِيَ الإِسْلامُ عَلَى خَمْسٍ: شَهَادَةِ أَنْ لاَ إِلَهَ إِلاَّ اللَّهُ وَأَنَّ مُحَمَّدًا رَسُولُ اللَّهِ، وَإِقَامِ الصَّلاَةِ، وَإِيتَاءِ الزَّكَاةِ، وَحَجِّ البَيْتِ، وَصَوْمِ رَمَضَانَ"@ar ;
    rel:teksLatin "Buniyal islamu 'ala khamsin: syahaadati an laa ilaaha illallah wa anna muhammadan rasuulullah, wa iqaamis-shalaati, wa iitaa'iz-zakaati, wa hajjil-baiti, wa shaumi ramadhaan."@id-Latn ;
    rel:terjemahan "Islam dibangun di atas lima perkara: bersaksi bahwa tidak ada tuhan yang berhak disembah selain Allah dan Muhammad adalah utusan Allah, mendirikan shalat, menunaikan zakat, haji ke Baitullah, dan puasa Ramadhan."@id .

