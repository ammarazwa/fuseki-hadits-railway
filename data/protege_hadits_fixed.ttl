           rel:memilikiFrasa ex:Frasa_6_1 ,
                             ex:Frasa_6_2 ;
           rel:jumlahKarakterArab 23 ;
           rel:terjemahan "Agama adalah nasihat."@id ;
           rel:teksArab "الدِّيْنُ النَّصِيْحَةُ"@ar ;
           rel:teksLatin "Ad-diinu an-nashiihah."@id-latn .


###  http://proyekakhir.ac.id/concept/Hadis_7
ex:Hadis_7 rdf:type owl:NamedIndividual ,
                    ex:Hadis ;
           rel:diriwayatkanOleh ex:Abu_Hurairah ;
           rel:membahasTopik ex:Meninggalkan_yang_Tidak_Bermanfaat ;
           rel:memilikiFrasa ex:Frasa_7_1 ,
                             ex:Frasa_7_2 ,
                             ex:Frasa_7_3 ;
           rel:jumlahKarakterArab 57 ;
           rel:terjemahan "Di antara tanda kebaikan keislaman seseorang adalah meninggalkan hal-hal yang tidak bermanfaat baginya."@id ;
           rel:teksArab "مِنْ حُسْنِ إِسْلامِ الْمَرْءِ تَرْكُهُ مَا لاَ يَعْنِيهِ"@ar ;
           rel:teksLatin "Min husni islaamil mar'i tarkuhu maa laa ya'niihi."@id-latn .


###  http://proyekakhir.ac.id/concept/Hadis_8
ex:Hadis_8 rdf:type owl:NamedIndividual ,
                    ex:Hadis ;
           rel:diriwayatkanOleh ex:Abu_Hurairah ;
