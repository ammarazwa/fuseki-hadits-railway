@prefix ex: <http://proyekakhir.ac.id/concept/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rel: <http://proyekakhir.ac.id/relation/> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.w3.org/2002/07/owl#> .

[ rdf:type owl:Ontology
 ] .

#################################################################
#    Annotation properties
#################################################################

###  http://proyekakhir.ac.id/relation/teksArab
rel:teksArab rdf:type owl:AnnotationProperty .


###  http://proyekakhir.ac.id/relation/teksLatin
rel:teksLatin rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://proyekakhir.ac.id/relation/diriwayatkanOleh
rel:diriwayatkanOleh rdf:type owl:ObjectProperty ;
                     rdfs:domain ex:Hadis ;
                     rdfs:range ex:Perawi .


###  http://proyekakhir.ac.id/relation/membahasTopik
rel:membahasTopik rdf:type owl:ObjectProperty ;
                  rdfs:domain ex:Hadis ;
                  rdfs:range ex:Topik .


###  http://proyekakhir.ac.id/relation/memilikiFrasa
rel:memilikiFrasa rdf:type owl:ObjectProperty ;
                  rdfs:domain ex:Hadis ;
                  rdfs:range ex:Frasa .


###  http://proyekakhir.ac.id/relation/munculDalam
rel:munculDalam rdf:type owl:ObjectProperty ;
                rdfs:domain ex:Frasa ;
                rdfs:range ex:Hadis .


#################################################################
#    Data properties
#################################################################

###  http://proyekakhir.ac.id/relation/jumlahKarakterArab
rel:jumlahKarakterArab rdf:type owl:DatatypeProperty ;
                       rdfs:domain ex:Hadis ;
                       rdfs:range xsd:integer .


###  http://proyekakhir.ac.id/relation/teks_arab
rel:teks_arab rdf:type owl:DatatypeProperty ;
              rdfs:domain ex:Hadis ;
              rdfs:range xsd:string .


###  http://proyekakhir.ac.id/relation/teks_latin
rel:teks_latin rdf:type owl:DatatypeProperty ;
               rdfs:domain ex:Hadis ;
               rdfs:range xsd:string .


###  http://proyekakhir.ac.id/relation/terjemahan
rel:terjemahan rdf:type owl:DatatypeProperty ;
               rdfs:domain ex:Hadis ;
               rdfs:range xsd:string .


#################################################################
#    Classes
#################################################################

###  http://proyekakhir.ac.id/concept/Perawi
ex:Perawi rdf:type owl:Class .


###  http://proyekakhir.ac.id/concept/Topik
ex:Topik rdf:type owl:Class .


###  http://proyekakhir.ac.id/concept/Frasa
ex:Frasa rdf:type owl:Class .


###  http://proyekakhir.ac.id/concept/Hadis
ex:Hadis rdf:type owl:Class .


###  http://proyekakhir.ac.id/concept/Perawi
ex:Perawi rdf:type owl:Class ;
          owl:deprecated "true"^^xsd:boolean .


